# --- The Golden Sentry configuration ---
# Copy this file to .env and fill in what you have.
# The app runs fully in DEMO MODE with no keys at all.

# EIA (U.S. Energy Information Administration) API key — free, instant:
# https://www.eia.gov/opendata/register.php
# When set, the dashboard pulls real hourly grid demand data.
EIA_API_KEY=

# Anthropic API key — enables the AI watch officer brief.
# Without it, a deterministic rule-based brief is generated instead.
ANTHROPIC_API_KEY=

# How often the ingestion/analysis cycle runs, in minutes.
REFRESH_MINUTES=5
